# 把这里替换成你的接收地址（Webhook URL）
# 例如：企业微信/飞书/Slack webhook、Zapier/Make 的 webhook 等
CONTACT_WEBHOOK_URL=

# 飞书群机器人若开启「关键词」安全设置，必须与这里填写的词完全一致（会出现在标题和正文首行）
# 若飞书返回 code 19024 Key Words Not Found，请填写此项或去飞书后台关闭关键词校验
FEISHU_WEBHOOK_KEYWORD=

# 公众号「华草视界」点击跳转地址（用浏览器打开公众号主页后，复制地址栏完整 https 链接）
# 未配置时页面仍显示「华草视界」文字，但不可点击
NEXT_PUBLIC_WECHAT_OFFICIAL_URL=

# 公众号二维码图片路径（放在 public 下），点击「华草视界」会弹窗展示二维码
# 例如你把二维码文件放到 public/images/wechat-qr.png，这里就填：
NEXT_PUBLIC_WECHAT_QR_IMAGE=/images/wechat-qr.png

# 网站正式域名（用于 sitemap、分享链接等，不要末尾斜杠）
# NEXT_PUBLIC_SITE_URL=https://gyzjhcxa.com

# --- Sanity 内容管理（管理后台：https://你的域名/studio）---
# 在 https://www.sanity.io/manage 创建项目后填写 Project ID（约 8 位字符）
NEXT_PUBLIC_SANITY_PROJECT_ID=

# 百度统计 hm.js 站点 ID（与 tongji.baidu.com「代码获取」里 hm.js? 后的 id 一致；可不填，代码内有默认）
NEXT_PUBLIC_BAIDU_HM_ID=

NEXT_PUBLIC_SANITY_DATASET=production

